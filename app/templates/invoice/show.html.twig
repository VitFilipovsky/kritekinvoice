{% extends 'base.html.twig' %}

{% block title %}Invoice #{{ invoice.invoiceNumber }}{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h1 class="h4 mb-0">Invoice #{{ invoice.invoiceNumber }}</h1>
            <div class="d-flex gap-2">
                <a href="{{ path('app_invoice_index') }}" class="btn btn-light btn-sm">All invoices</a>
                <a href="{{ path('app_invoice_new') }}" class="btn btn-light btn-sm">+ New invoice</a>
            </div>
        </div>
        <div class="card-body">
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="fw-semibold text-secondary small text-uppercase">Invoice date</div>
                    <div class="fs-5">{{ invoice.invoiceDate|date('d.m.Y') }}</div>
                </div>
                <div class="col-md-4">
                    <div class="fw-semibold text-secondary small text-uppercase">Customer ID</div>
                    <div class="fs-5">{{ invoice.customerId }}</div>
                </div>
            </div>

            <h2 class="h5 text-secondary mb-3">Invoice lines</h2>
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Description</th>
                            <th class="text-end">Quantity</th>
                            <th class="text-end">Amount</th>
                            <th class="text-end">VAT amount</th>
                            <th class="text-end">Total with VAT</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for line in invoice.lines %}
                            <tr>
                                <td>{{ line.description }}</td>
                                <td class="text-end">{{ line.quantity }}</td>
                                <td class="text-end">{{ line.amount }}</td>
                                <td class="text-end">{{ line.vatAmount }}</td>
                                <td class="text-end fw-semibold">{{ line.totalWithVat }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center text-secondary py-4">No lines.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <hr class="my-4">
            <div class="d-flex flex-wrap gap-2">
                <a href="{{ path('app_invoice_index') }}" class="btn btn-outline-secondary">All invoices</a>
                <a href="{{ path('app_invoice_new') }}" class="btn btn-outline-primary">Create another invoice</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
