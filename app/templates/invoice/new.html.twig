{% extends 'base.html.twig' %}

{% block title %}New invoice{% endblock %}

{% block body %}
    <h1>Create invoice</h1>

    {{ form_start(form) }}
        {{ form_row(form.invoiceDate) }}
        {{ form_row(form.invoiceNumber) }}
        {{ form_row(form.customerId) }}

        <h2>Invoice lines</h2>
        <ul class="invoice-lines" data-prototype="{{ form_widget(form.lines.vars.prototype)|e('html_attr') }}" data-index="{{ form.lines|length }}">
            {% for line in form.lines %}
                <li>{{ form_row(line) }}</li>
            {% endfor %}
        </ul>
        <button type="button" class="add-line" data-collection-holder="invoice_lines">Add line</button>

        <div class="form-actions">
            <button type="submit">Save invoice</button>
        </div>
    {{ form_end(form) }}

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const addButton = document.querySelector('.add-line');
            const list = document.querySelector('.invoice-lines');
            if (!addButton || !list) return;

            addButton.addEventListener('click', function() {
                const index = list.dataset.index || list.children.length;
                const prototype = list.dataset.prototype;
                const newRow = prototype.replace(/__name__/g, index);
                list.insertAdjacentHTML('beforeend', '<li>' + newRow + '</li>');
                list.dataset.index = parseInt(index, 10) + 1;
            });
        });
    </script>
{% endblock %}
