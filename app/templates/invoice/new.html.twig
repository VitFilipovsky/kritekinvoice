{% extends 'base.html.twig' %}

{% block title %}New invoice{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h1 class="h4 mb-0">Create invoice</h1>
            <a href="{{ path('app_invoice_index') }}" class="btn btn-light btn-sm">All invoices</a>
        </div>
        <div class="card-body">
            {{ form_start(form) }}
                <div class="row">
                    <div class="col-lg-4">
                        {{ form_row(form.invoiceDate) }}
                    </div>
                    <div class="col-lg-4">
                        {{ form_row(form.invoiceNumber) }}
                    </div>
                    <div class="col-lg-4">
                        {{ form_row(form.customerId) }}
                    </div>
                </div>

                <hr class="my-4">

                <h2 class="h5 text-secondary mb-3">Invoice lines</h2>
                <div data-controller="invoice-lines">
                    <ul class="list-unstyled invoice-lines mb-3"
                        data-invoice-lines-target="list"
                        data-prototype="{{ form_widget(form.lines.vars.prototype)|e('html_attr') }}"
                        data-index="{{ form.lines|length }}">
                        {% for line in form.lines %}
                            <li class="mb-3">
                                <div class="card border-secondary-subtle">
                                    <div class="card-body bg-white">
                                        {{ form_widget(line) }}
                                    </div>
                                </div>
                            </li>
                        {% endfor %}
                    </ul>

                    <button type="button" class="btn btn-outline-primary btn-sm mb-4"
                            data-invoice-lines-target="addButton">
                        + Add line
                    </button>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <button type="submit" class="btn btn-primary btn-lg px-5">Save invoice</button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
